generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BUSINESS
  ARCHITECT
}

enum ArchitectStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProjectStatus {
  OPEN
  PROPOSAL_REVIEW
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ConnectorProvider {
  GMAIL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         UserRole
  fullName     String?
  isSuspended  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  architectProfile     ArchitectProfile?
  workflows            WorkflowDefinition[]
  listings             AgentListing[]
  proposals            ProjectProposal[]
  connectorCredentials ConnectorCredential[]

  @@index([role])
  @@index([createdAt])
}

model ArchitectProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  title           String?
  bio             String?
  portfolioUrl    String?
  skills          String[]
  hourlyRateCents Int?
  approvalStatus  ArchitectStatus @default(PENDING)
  rating          Float           @default(0)
  completedJobs   Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([approvalStatus])
}

model WorkflowDefinition {
  id              String   @id @default(cuid())
  architectUserId String
  name            String
  description     String?
  workflowJson    Json
  isTemplate      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  architect User           @relation(fields: [architectUserId], references: [id], onDelete: Cascade)
  listings  AgentListing[]

  @@index([architectUserId])
  @@index([createdAt])
}

model AgentListing {
  id                 String        @id @default(cuid())
  architectUserId    String
  workflowId         String?
  name               String
  shortDescription   String
  description        String?
  priceCents         Int           @default(0)
  status             ListingStatus @default(DRAFT)
  tags               String[]
  requiredConnectors String[]
  supportedLlms      String[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  architect User                @relation(fields: [architectUserId], references: [id], onDelete: Cascade)
  workflow  WorkflowDefinition? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@index([architectUserId])
  @@index([workflowId])
  @@index([status])
}

model Project {
  id                 String        @id @default(cuid())
  title              String
  requirementBrief   String
  requiredConnectors String[]
  preferredLlms      String[]
  budgetMinCents     Int?
  budgetMaxCents     Int?
  status             ProjectStatus @default(OPEN)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  proposals ProjectProposal[]

  @@index([status])
  @@index([createdAt])
}

model ProjectProposal {
  id              String         @id @default(cuid())
  projectId       String
  architectUserId String
  coverLetter     String
  bidAmountCents  Int?
  etaDays         Int?
  status          ProposalStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  architect User    @relation(fields: [architectUserId], references: [id], onDelete: Cascade)

  @@unique([projectId, architectUserId])
  @@index([architectUserId])
  @@index([projectId])
  @@index([status])
}

model ConnectorCredential {
  id                   String            @id @default(cuid())
  userId               String
  provider             ConnectorProvider
  externalAccountEmail String?
  accessTokenEnc       String?
  refreshTokenEnc      String?
  scope                String?
  tokenType            String?
  expiresAt            DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}
