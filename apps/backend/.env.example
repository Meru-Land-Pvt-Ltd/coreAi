# CoreAI backend environment template.
# Copy to .env and fill in real values. NEVER commit real secrets — only this
# example (with empty/placeholder values) is tracked.

# ---- Core ----
NODE_ENV=development
PORT=8787
DATABASE_URL=postgresql://user:password@localhost:5432/coreai
REDIS_URL=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN_DAYS=7
ENCRYPTION_KEY=change-me-to-a-long-random-string
PLATFORM_COMMISSION_PERCENT=15
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8787

# ---- Google (Calendar + Gmail OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=America/New_York

# ---- Twilio (platform-owned telephony for MVP) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_TEST_MODE=false
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_DEFAULT_BUSINESS_NAME=
TWILIO_FORWARD_TO_PHONE=
TWILIO_FORWARD_TIMEOUT_SECONDS=20
TWILIO_DEFAULT_BOOKING_URL=
TWILIO_DEFAULT_TEAM_PHONE=
TWILIO_NUMBER_POOL=

# ---- Vapi (live voice agent platform) ----
VAPI_API_KEY=
VAPI_BASE_URL=https://api.vapi.ai
VAPI_DEFAULT_ASSISTANT_ID=
VAPI_DEFAULT_PHONE_NUMBER_ID=
VAPI_ANSWER_INBOUND=false

# ---- Voice (ElevenLabs through Vapi) ----
# VAPI_DEFAULT_VOICE_PROVIDER + VAPI_DEFAULT_VOICE_ID are the deploy/preview
# fallback when a preset/custom voice doesn't resolve.
VAPI_DEFAULT_VOICE_PROVIDER=11labs
VAPI_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_API_KEY powers voice PREVIEW (TTS) only; live calls use Vapi.
# Without it, the voice picker degrades to a clean "preview unavailable" message.
# The key NEVER leaves the backend.
ELEVENLABS_API_KEY=
# Per-preset voice id overrides (override the built-in preset defaults).
ELEVENLABS_VOICE_SARAH_ID=
ELEVENLABS_VOICE_ARIA_ID=
ELEVENLABS_VOICE_RACHEL_ID=
ELEVENLABS_VOICE_ADAM_ID=
ELEVENLABS_VOICE_PRIYA_ID=

# ---- Stripe (billing) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_AI_RECEPTIONIST_MONTHLY=
